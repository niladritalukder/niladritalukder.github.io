TITLE = {An In-Depth Exploration of the Electrochemical Oxygen Reduction Reaction (ORR) Phenomenon on Carbon-Based Catalysts in Alkaline and Acidic Mediums},
JOURNAL = {Catalysts},
VOLUME = {12},
YEAR = {2022},
NUMBER = {7},
